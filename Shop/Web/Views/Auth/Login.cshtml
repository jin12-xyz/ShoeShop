@model Shop.Web.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null; // ← no layout for auth pages
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — ShopNest</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">

    <div class="w-full max-w-md">

        <!-- Logo -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900">ShopNest</h1>
            <p class="text-gray-500 mt-1">Welcome back!</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">

            <h2 class="text-xl font-semibold text-gray-800 mb-6">Sign in to your account</h2>

            <!-- Success Message -->
            @if (TempData["Success"] != null)
            {
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm">
                    @TempData["Success"]
                </div>
            }

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
                    <asp-validation-summary asp-validation-summary="All" class="list-none m-0 p-0" />
                </div>
            }

            <!-- Form -->
            <form asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()

                <!-- ReturnUrl -->
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <!-- Email -->
                <div class="mb-4">
                    <label asp-for="Email"
                           class="block text-sm font-medium text-gray-700 mb-1">
                    </label>
                    <input asp-for="Email"
                           type="email"
                           placeholder="you@example.com"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <div class="flex justify-between items-center mb-1">
                        <label asp-for="Password"
                               class="block text-sm font-medium text-gray-700">
                        </label>
                        <a href="#" class="text-xs text-gray-500 hover:text-black transition">
                            Forgot password?
                        </a>
                    </div>
                    <input asp-for="Password"
                           type="password"
                           placeholder="••••••••"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center mb-6">
                    <input asp-for="RememberMe"
                           type="checkbox"
                           class="w-4 h-4 border-gray-300 rounded text-black
                                  focus:ring-black cursor-pointer" />
                    <label asp-for="RememberMe"
                           class="ml-2 text-sm text-gray-600 cursor-pointer">
                    </label>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full bg-black text-white py-2.5 rounded-lg text-sm font-medium
                               hover:bg-gray-800 transition duration-150 cursor-pointer">
                    Sign in
                </button>

            </form>

            <!-- Divider -->
            <div class="flex items-center my-6">
                <div class="flex-1 border-t border-gray-200"></div>
                <span class="px-3 text-xs text-gray-400">or</span>
                <div class="flex-1 border-t border-gray-200"></div>
            </div>

            <!-- Register Link -->
            <p class="text-center text-sm text-gray-500">
                Don't have an account?
                <a asp-action="Register" asp-controller="Auth"
                   class="text-black font-medium hover:underline">
                    Create one
                </a>
            </p>

        </div>
    </div>
    <!-- Client side validation -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>