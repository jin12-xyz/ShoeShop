@model Shop.Web.ViewModels.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register — ShopNest</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center py-10">

    <div class="w-full max-w-md">

        <!-- Logo -->
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900">ShopNest</h1>
            <p class="text-gray-500 mt-1">Create your account</p>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">

            <h2 class="text-xl font-semibold text-gray-800 mb-6">Get started for free</h2>

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm">
                    <asp-validation-summary asp-validation-summary="All" class="list-none m-0 p-0" />
                </div>
            }

            <!-- Form -->
            <form asp-action="Register" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()

                <!-- Full Name -->
                <div class="mb-4">
                    <label asp-for="Fullname"
                           class="block text-sm font-medium text-gray-700 mb-1">
                    </label>
                    <input asp-for="Fullname"
                           type="text"
                           placeholder="John Doe"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="Fullname" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Email -->
                <div class="mb-4">
                    <label asp-for="Email"
                           class="block text-sm font-medium text-gray-700 mb-1">
                    </label>
                    <input asp-for="Email"
                           type="email"
                           placeholder="you@example.com"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Phone Number -->
                <div class="mb-4">
                    <label asp-for="PhoneNumber"
                           class="block text-sm font-medium text-gray-700 mb-1">
                    </label>
                    <input asp-for="PhoneNumber"
                           type="tel"
                           placeholder="+63 912 345 6789"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <label asp-for="Password"
                           class="block text-sm font-medium text-gray-700 mb-1">
                    </label>
                    <input asp-for="Password"
                           type="password"
                           placeholder="Min. 8 characters"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Confirm Password -->
                <div class="mb-6">
                    <label asp-for="ConfirmPassword"
                           class="block text-sm font-medium text-gray-700 mb-1">
                    </label>
                    <input asp-for="ConfirmPassword"
                           type="password"
                           placeholder="Repeat your password"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm
                                  focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent
                                  transition duration-150" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full bg-black text-white py-2.5 rounded-lg text-sm font-medium
                               hover:bg-gray-800 transition duration-150 cursor-pointer">
                    Create account
                </button>

            </form>

            <!-- Login Link -->
            <p class="text-center text-sm text-gray-500 mt-6">
                Already have an account?
                <a asp-action="Login" asp-controller="Auth"
                   class="text-black font-medium hover:underline">
                    Sign in
                </a>
            </p>

        </div>
    </div>
    <!-- Client side validation -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>