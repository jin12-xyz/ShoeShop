@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Denied — ShopNest</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">

    <div class="text-center">
        <h1 class="text-6xl font-bold text-gray-900 mb-4">403</h1>
        <p class="text-xl text-gray-600 mb-2">Access Denied</p>
        <p class="text-gray-400 text-sm mb-8">
            You don't have permission to access this page.
        </p>
        <a asp-action="Login" asp-controller="Auth"
           class="bg-black text-white px-6 py-2.5 rounded-lg text-sm
                  font-medium hover:bg-gray-800 transition duration-150">
            Back to Login
        </a>
    </div>

</body>
</html>