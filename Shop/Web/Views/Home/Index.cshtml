@{
    ViewData["Title"] = "Home";
}

@* ================================ *@
@* HERO SECTION                     *@
@* ================================ *@
<section class="relative bg-gray-900 rounded-2xl overflow-hidden mb-12">
    <div class="absolute inset-0">
        @* -------------------------------- *@
        @* Add hero background image here  *@
        @* e.g.                            *@
        @* <img src="~/images/hero.jpg"    *@
        @*      class="w-full h-full       *@
        @*      object-cover opacity-40"/> *@
        @* -------------------------------- *@
        <div class="w-full h-full bg-gradient-to-r
                    from-gray-900 to-gray-700 opacity-90">
        </div>
    </div>

    <div class="relative max-w-3xl px-8 py-24 md:py-32">
        @* -------------------------------- *@
        @* Hero Badge                       *@
        @* -------------------------------- *@
        <span class="inline-block bg-white/10 text-white text-xs
                     font-medium px-3 py-1 rounded-full mb-4
                     tracking-wider uppercase">
            New Collection 2025
        </span>

        @* -------------------------------- *@
        @* Hero Headline                    *@
        @* -------------------------------- *@
        <h1 class="text-4xl md:text-5xl font-bold text-white
                   leading-tight mb-4">
            Wear Your <br />
            <span class="text-gray-300">Confidence</span>
        </h1>

        @* -------------------------------- *@
        @* Hero Subheadline                 *@
        @* -------------------------------- *@
        <p class="text-gray-400 text-base md:text-lg mb-8 max-w-xl">
            Discover the latest trends in fashion —
            from streetwear to formal wear,
            we have everything you need.
        </p>

        @* -------------------------------- *@
        @* Hero CTA Buttons                 *@
        @* -------------------------------- *@
        <div class="flex flex-wrap gap-3">
            <a asp-action="Index" asp-controller="Product"
               class="bg-white text-gray-900 px-6 py-3 rounded-lg
                      text-sm font-medium hover:bg-gray-100 transition">
                Shop Now
            </a>
            <a asp-action="Index" asp-controller="Category"
               class="bg-transparent text-white border border-white/30
                      px-6 py-3 rounded-lg text-sm font-medium
                      hover:bg-white/10 transition">
                Browse Categories
            </a>
        </div>
    </div>
</section>

@* ================================ *@
@* FEATURED CATEGORIES              *@
@* ================================ *@
<section class="mb-12">

    @* Section Header *@
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">
                Shop by Category
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                Find what you're looking for
            </p>
        </div>
        <a asp-action="Index" asp-controller="Category"
           class="text-sm text-gray-500 hover:text-gray-900 transition">
            View all →
        </a>
    </div>

    @* -------------------------------- *@
    @* Category Cards                   *@
    @* Replace placeholders with real   *@
    @* categories when Category feature *@
    @* is built                         *@
    @* -------------------------------- *@
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        @foreach (var category in new[] {
                new { Name = "Men's Wear", Icon = "👔" },
                new { Name = "Women's", Icon = "👗" },
                new { Name = "Streetwear", Icon = "🧢" },
                new { Name = "Accessories", Icon = "👜" },
                new { Name = "Footwear", Icon = "👟" },
                new { Name = "Activewear", Icon = "🏃" }
                })
        {
            <a href="#"
               class="bg-white border border-gray-100 rounded-xl p-4
                          text-center hover:border-gray-300 hover:shadow-sm
                          transition group">
                <div class="text-3xl mb-2">@category.Icon</div>
                <p class="text-xs font-medium text-gray-700
                              group-hover:text-gray-900 transition">
                    @category.Name
                </p>
            </a>
        }
    </div>

</section>

@* ================================ *@
@* PROMOTIONAL BANNER               *@
@* ================================ *@
<section class="mb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        @* Banner 1 *@
        <div class="bg-gray-900 rounded-2xl p-8 flex flex-col justify-between
                    min-h-48 relative overflow-hidden">
            @* -------------------------------- *@
            @* Add banner image here later      *@
            @* -------------------------------- *@
            <div>
                <p class="text-gray-400 text-xs uppercase tracking-wider mb-2">
                    Limited Offer
                </p>
                <h3 class="text-white text-2xl font-bold mb-2">
                    Up to 50% Off
                </h3>
                <p class="text-gray-400 text-sm">
                    On selected streetwear items
                </p>
            </div>
            <a href="#"
               class="inline-block bg-white text-gray-900 text-sm
                      font-medium px-4 py-2 rounded-lg mt-4
                      hover:bg-gray-100 transition w-fit">
                Shop Sale
            </a>
        </div>

        @* Banner 2 *@
        <div class="bg-gray-100 rounded-2xl p-8 flex flex-col
                    justify-between min-h-48 relative overflow-hidden">
            @* -------------------------------- *@
            @* Add banner image here later      *@
            @* -------------------------------- *@
            <div>
                <p class="text-gray-500 text-xs uppercase tracking-wider mb-2">
                    New Arrivals
                </p>
                <h3 class="text-gray-900 text-2xl font-bold mb-2">
                    Summer 2025
                </h3>
                <p class="text-gray-500 text-sm">
                    Fresh styles just dropped
                </p>
            </div>
            <a href="#"
               class="inline-block bg-gray-900 text-white text-sm
                      font-medium px-4 py-2 rounded-lg mt-4
                      hover:bg-gray-800 transition w-fit">
                Explore Now
            </a>
        </div>

    </div>
</section>

@* ================================ *@
@* LATEST PRODUCTS                  *@
@* ================================ *@
<section class="mb-12">

    @* Section Header *@
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">
                Latest Products
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                Just arrived in our store
            </p>
        </div>
        <a asp-action="Index" asp-controller="Product"
           class="text-sm text-gray-500 hover:text-gray-900 transition">
            View all →
        </a>
    </div>

    @* -------------------------------- *@
    @* Product Cards                    *@
    @* Replace with real products when  *@
    @* Product feature is built         *@
    @* -------------------------------- *@
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        @for (int i = 1; i <= 8; i++)
        {
            <div class="group cursor-pointer">
                @* Product Image Placeholder *@
                <div class="bg-gray-100 rounded-xl aspect-square mb-3
                                overflow-hidden relative">
                    @* -------------------------------- *@
                    @* Add product image here later     *@
                    @* <img src="@product.ImageUrl"     *@
                    @*      class="w-full h-full        *@
                    @*      object-cover group-hover:   *@
                    @*      scale-105 transition"/>     *@
                    @* -------------------------------- *@
                    <div class="w-full h-full flex items-center
                                    justify-center text-gray-300 text-4xl">
                        👟
                    </div>

                    @* Wishlist Button *@
                    @* -------------------------------- *@
                    @* Add wishlist functionality later *@
                    @* -------------------------------- *@
                    <button class="absolute top-3 right-3 bg-white
                                       rounded-full p-1.5 opacity-0
                                       group-hover:opacity-100 transition
                                       shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             class="h-4 w-4 text-gray-400"
                             fill="none" viewBox="0 0 24 24"
                             stroke="currentColor">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="1.5"
                                  d="M4.318 6.318a4.5 4.5 0 000
                                         6.364L12 20.364l7.682-7.682a4.5
                                         4.5 0 00-6.364-6.364L12 7.636l-1.318
                                         -1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                    </button>
                </div>

                @* Product Info *@
                <div>
                    @* -------------------------------- *@
                    @* Replace with real product data  *@
                    @* -------------------------------- *@
                    <p class="text-xs text-gray-400 mb-1">
                        Category Name
                    </p>
                    <h3 class="text-sm font-medium text-gray-900
                                   mb-1 truncate">
                        Product Name @i
                    </h3>
                    <div class="flex items-center justify-between">
                        <p class="text-sm font-semibold text-gray-900">
                            $00.00
                        </p>
                        @* -------------------------------- *@
                        @* Add to cart button              *@
                        @* Add cart functionality later    *@
                        @* -------------------------------- *@
                        <button class="bg-gray-900 text-white text-xs
                                           px-3 py-1.5 rounded-lg
                                           hover:bg-gray-700 transition">
                            Add to Cart
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

</section>

@* ================================ *@
@* FEATURES / USP SECTION           *@
@* ================================ *@
<section class="mb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

        @foreach (var feature in new[] {
                new { Icon = "🚚", Title = "Free Shipping",
                Desc = "On orders over $50" },
                new { Icon = "↩️", Title = "Easy Returns",
                Desc = "30 day return policy" },
                new { Icon = "🔒", Title = "Secure Payment",
                Desc = "100% secure checkout" },
                new { Icon = "💬", Title = "24/7 Support",
                Desc = "We're here to help" }
                })
        {
            <div class="bg-white border border-gray-100 rounded-xl
                            p-5 text-center">
                <div class="text-2xl mb-2">@feature.Icon</div>
                <h4 class="text-sm font-semibold text-gray-900 mb-1">
                    @feature.Title
                </h4>
                <p class="text-xs text-gray-500">@feature.Desc</p>
            </div>
        }

    </div>
</section>

@* ================================ *@
@* NEWSLETTER SECTION               *@
@* ================================ *@
<section class="mb-12">
    <div class="bg-gray-900 rounded-2xl px-8 py-12 text-center">
        <h2 class="text-2xl font-bold text-white mb-2">
            Stay in the Loop
        </h2>
        <p class="text-gray-400 text-sm mb-6">
            Subscribe to get the latest arrivals and
            exclusive offers.
        </p>

        @* -------------------------------- *@
        @* Add newsletter form here later   *@
        @* -------------------------------- *@
        <div class="flex flex-col sm:flex-row gap-3
                    max-w-md mx-auto">
            <input type="email"
                   placeholder="Enter your email"
                   class="flex-1 px-4 py-2.5 rounded-lg text-sm
                          bg-white/10 text-white placeholder-gray-500
                          border border-white/10
                          focus:outline-none focus:border-white/30" />
            <button class="bg-white text-gray-900 px-6 py-2.5
                           rounded-lg text-sm font-medium
                           hover:bg-gray-100 transition whitespace-nowrap">
                Subscribe
            </button>
        </div>

    </div>
</section>