@model Shop.Web.ViewModels.Category.CategoryFormViewModel
@{
    ViewData["Title"] = "Edit Category";
}

@* Page Header *@
<div class="mb-6">
    <a asp-action="Index"
       class="text-sm text-gray-500 hover:text-gray-900
              transition flex items-center gap-1 mb-4">
        ← Back to Categories
    </a>
    <h1 class="text-2xl font-semibold text-gray-900">
        Edit Category
    </h1>
    <p class="text-sm text-gray-500 mt-1">
        Update category details
    </p>
</div>

@* Form Card *@
<div class="bg-white border border-gray-100 rounded-2xl p-8 max-w-xl">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        @* Hidden Id *@
        <input asp-for="Id" type="hidden" />

        @* Name *@
        <div class="mb-5">
            <label asp-for="Name"
                   class="block text-sm font-medium text-gray-700 mb-1">
            </label>
            <input asp-for="Name"
                   type="text"
                   class="w-full px-4 py-2.5 border border-gray-300
                          rounded-lg text-sm focus:outline-none
                          focus:ring-2 focus:ring-black
                          focus:border-transparent transition" />
            <span asp-validation-for="Name"
                  class="text-red-500 text-xs mt-1 block">
            </span>
        </div>

        @* Description *@
        <div class="mb-6">
            <label asp-for="Description"
                   class="block text-sm font-medium text-gray-700 mb-1">
            </label>
            <textarea asp-for="Description"
                      rows="3"
                      class="w-full px-4 py-2.5 border border-gray-300
                             rounded-lg text-sm focus:outline-none
                             focus:ring-2 focus:ring-black
                             focus:border-transparent transition resize-none">
            </textarea>
            <span asp-validation-for="Description"
                  class="text-red-500 text-xs mt-1 block">
            </span>
        </div>

        @* Buttons *@
        <div class="flex items-center gap-3">
            <button type="submit"
                    class="bg-black text-white px-6 py-2.5 rounded-lg
                           text-sm font-medium hover:bg-gray-800 transition">
                Save Changes
            </button>
            <a asp-action="Index"
               class="text-sm text-gray-500 hover:text-gray-900 transition">
                Cancel
            </a>
        </div>

    </form>
</div>