<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ShoeShop</title>
    <link rel="stylesheet" href="~/css/animations.css" />
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50:  '#fff7ed',
                            100: '#ffedd5',
                            500: '#f97316',
                            600: '#ea580c',
                            700: '#c2410c',
                        }
                    },
                    fontFamily: {
                        display: ['"Playfair Display"', 'Georgia', 'serif'],
                        body:    ['"DM Sans"', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- X.PagedList CSS (optional; swap for your actual CDN / local copy) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/x.pagedlist/9.1.2/X.PagedList.css" />
</head>
<body class="bg-stone-50 text-stone-800 flex flex-col min-h-screen">

    <!-- ╔══════════════════════════════════╗ -->
    <!-- ║            TOP BAR              ║ -->
    <!-- ╚══════════════════════════════════╝ -->
    <div class="bg-stone-900 text-stone-300 text-xs text-center py-1.5 tracking-wider">
        Free shipping on orders over ₱2,000 &nbsp;|&nbsp; New arrivals every Friday
    </div>

    <!-- ╔══════════════════════════════════╗ -->
    <!-- ║             NAVBAR              ║ -->
    <!-- ╚══════════════════════════════════╝ -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-stone-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <nav class="flex items-center justify-between h-16">

                <!-- Logo -->
                <a asp-controller="Home" asp-action="Index"
                   class="font-display text-2xl font-bold tracking-tight text-stone-900 hover:text-brand-600 transition-colors">
                    Shoe<span class="text-brand-500">Shop</span>
                </a>

                <!-- Centre links (desktop) -->
                <ul class="hidden md:flex items-center gap-1 text-sm font-medium">
                    <li>
                        <a asp-controller="Home" asp-action="Index"
                           class="px-3 py-2 rounded-lg text-stone-600 hover:text-brand-600 hover:bg-brand-50 transition-all">
                            Home
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Product" asp-action="Index"
                           class="px-3 py-2 rounded-lg text-stone-600 hover:text-brand-600 hover:bg-brand-50 transition-all">
                            Products
                        </a>
                    </li>
                    <li>
                        <!-- Category mega-link (desktop) -->
                        <div class="relative group">
                            <button class="flex items-center gap-1 px-3 py-2 rounded-lg text-stone-600 hover:text-brand-600 hover:bg-brand-50 transition-all">
                                Categories
                                <svg class="w-3.5 h-3.5 mt-0.5 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>
                            <!-- Dropdown populated server-side via ViewBag or partial -->
                            <div class="dropdown-enter absolute left-0 top-full mt-1 w-48 bg-white rounded-xl shadow-xl border border-stone-100 py-2 hidden group-hover:block">
                                @if (ViewBag.NavCategories != null)
                                {
                                    foreach (var cat in ViewBag.NavCategories as IEnumerable<Shop.Application.DTOs.Category.CategoryDto>)
                                    {
                                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@cat.Id"
                                           class="block px-4 py-2 text-sm text-stone-700 hover:bg-brand-50 hover:text-brand-600 transition-colors">
                                            @cat.Name
                                        </a>
                                    }
                                }
                                <div class="border-t border-stone-100 mt-1 pt-1">
                                    <a asp-controller="Category" asp-action="Index"
                                       class="block px-4 py-2 text-sm font-semibold text-brand-500 hover:bg-brand-50 transition-colors">
                                        All Categories →
                                    </a>
                                </div>
                            </div>
                        </div>
                    </li>
                    <li>
                        <a asp-controller="Home" asp-action="About"
                           class="px-3 py-2 rounded-lg text-stone-600 hover:text-brand-600 hover:bg-brand-50 transition-all">
                            About
                        </a>
                    </li>
                </ul>

                <!-- Right cluster -->
                <div class="flex items-center gap-2">

                    <!-- Search (desktop) -->
                    <form asp-controller="Product" asp-action="Index" method="get"
                          class="hidden md:flex items-center bg-stone-100 rounded-full px-4 py-1.5 gap-2 focus-within:ring-2 focus-within:ring-brand-400 transition-all">
                        <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <circle cx="11" cy="11" r="8" />
                            <path d="M21 21l-4.35-4.35" />
                        </svg>
                        <input type="text" name="search" placeholder="Search shoes…"
                               class="bg-transparent text-sm outline-none w-36 placeholder-stone-400" />
                    </form>

                    <!-- Cart -->
                    <a asp-controller="Cart" asp-action="Index"
                       class="relative p-2 rounded-lg text-stone-600 hover:text-brand-600 hover:bg-brand-50 transition-all"
                       title="Cart">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" />
                        </svg>
                        @{
                            var cartCount = ViewBag.CartCount as int? ?? 0;
                        }
                        @if (cartCount > 0)
                        {
                            <span id="cartBadge"
                                  class="badge-animate absolute -top-0.5 -right-0.5 bg-brand-500 text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center leading-none">
                                @(cartCount > 99 ? "99+" : cartCount.ToString())
                            </span>
                        }
                    </a>

                    <!-- User menu -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="relative group">
                            <button class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-stone-700 hover:bg-brand-50 hover:text-brand-600 transition-all text-sm font-medium">
                                <!-- Avatar initials -->
                                <span class="w-7 h-7 rounded-full bg-brand-500 text-white text-xs font-bold flex items-center justify-center uppercase">
                                    @(User.Identity.Name?.Length > 0 ? User.Identity.Name[0].ToString() : "U")
                                </span>
                                <span class="hidden lg:block max-w-[100px] truncate">@User.Identity.Name</span>
                                <svg class="w-3.5 h-3.5 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </button>
                            <div class="dropdown-enter absolute right-0 top-full mt-1 w-48 bg-white rounded-xl shadow-xl border border-stone-100 py-2 hidden group-hover:block z-50">
                                <a asp-controller="Account" asp-action="Profile"
                                   class="flex items-center gap-2 px-4 py-2 text-sm text-stone-700 hover:bg-brand-50 hover:text-brand-600 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.58-7 8-7s8 3 8 7" /></svg>
                                    My Profile
                                </a>
                                <a asp-controller="Order" asp-action="Index"
                                   class="flex items-center gap-2 px-4 py-2 text-sm text-stone-700 hover:bg-brand-50 hover:text-brand-600 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                                    My Orders
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="border-t border-stone-100 my-1"></div>
                                    <a asp-controller="Admin" asp-action="Dashboard"
                                       class="flex items-center gap-2 px-4 py-2 text-sm text-stone-700 hover:bg-brand-50 hover:text-brand-600 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                                        Admin Dashboard
                                    </a>
                                }
                                <div class="border-t border-stone-100 my-1"></div>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-500 hover:bg-red-50 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1" /></svg>
                                        Sign Out
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login"
                           class="text-sm font-medium text-stone-600 hover:text-brand-600 px-3 py-1.5 rounded-lg hover:bg-brand-50 transition-all">
                            Sign In
                        </a>
                        <a asp-controller="Auth" asp-action="Register"
                           class="text-sm font-semibold bg-brand-500 hover:bg-brand-600 text-white px-4 py-1.5 rounded-lg transition-all shadow-sm">
                            Register
                        </a>
                    }

                    <!-- Mobile hamburger -->
                    <button id="mobileMenuBtn"
                            class="md:hidden p-2 rounded-lg text-stone-600 hover:bg-brand-50 hover:text-brand-600 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </nav>
        </div>

        <!-- Mobile menu -->
        <div id="mobileMenu" class="hidden md:hidden border-t border-stone-200 bg-white px-4 pb-4 pt-2 space-y-1">
            <a asp-controller="Home" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm text-stone-700 hover:bg-brand-50">Home</a>
            <a asp-controller="Product" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm text-stone-700 hover:bg-brand-50">Products</a>
            <a asp-controller="Category" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm text-stone-700 hover:bg-brand-50">Categories</a>
            <a asp-controller="Cart" asp-action="Index" class="block px-3 py-2 rounded-lg text-sm text-stone-700 hover:bg-brand-50">Cart <!-- (cartCount)--></a>
            <form asp-controller="Product" asp-action="Index" method="get" class="flex items-center gap-2 bg-stone-100 rounded-lg px-3 py-2 mt-2">
                <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
                <input type="text" name="search" placeholder="Search…" class="bg-transparent text-sm outline-none w-full" />
            </form>
        </div>
    </header>

    <!-- ╔══════════════════════════════════╗ -->
    <!-- ║          TOAST ALERTS           ║ -->
    <!-- ╚══════════════════════════════════╝ -->
    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded-xl px-4 py-3 mb-2 shadow-sm">
                <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-2 shadow-sm">
                <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 8v4m0 4h.01" /></svg>
                @TempData["Error"]
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="flex items-center gap-3 bg-blue-50 border border-blue-200 text-blue-700 text-sm rounded-xl px-4 py-3 mb-2 shadow-sm">
                <svg class="w-5 h-5 text-blue-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 8v4m0 4h.01" /></svg>
                @TempData["Info"]
            </div>
        }
    </div>

    <!-- ╔══════════════════════════════════╗ -->
    <!-- ║           MAIN CONTENT          ║ -->
    <!-- ╚══════════════════════════════════╝ -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <!-- ╔══════════════════════════════════╗ -->
    <!-- ║             FOOTER              ║ -->
    <!-- ╚══════════════════════════════════╝ -->
    <footer class="bg-stone-900 text-stone-400 mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Brand -->
                <div>
                    <p class="font-display text-2xl font-bold text-white mb-3">
                        Shoe<span class="text-brand-500">Shop</span>
                    </p>
                    <p class="text-sm leading-relaxed">
                        Premium footwear for every step of your journey.
                    </p>
                </div>
                <!-- Shop -->
                <div>
                    <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Shop</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a asp-controller="Product" asp-action="Index" class="hover:text-brand-400 transition-colors">All Products</a></li>
                        <li><a asp-controller="Category" asp-action="Index" class="hover:text-brand-400 transition-colors">Categories</a></li>
                        <li><a asp-controller="Product" asp-action="NewArrivals" class="hover:text-brand-400 transition-colors">New Arrivals</a></li>
                        <li><a asp-controller="Product" asp-action="Sale" class="hover:text-brand-400 transition-colors">Sale</a></li>
                    </ul>
                </div>
                <!-- Account -->
                <div>
                    <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Account</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a asp-controller="Auth" asp-action="Login" class="hover:text-brand-400 transition-colors">Sign In</a></li>
                        <li><a asp-controller="Auth" asp-action="Register" class="hover:text-brand-400 transition-colors">Create Account</a></li>
                        <li><a asp-controller="Order" asp-action="Index" class="hover:text-brand-400 transition-colors">My Orders</a></li>
                    </ul>
                </div>
                <!-- Help -->
                <div>
                    <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Help</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a asp-controller="Home" asp-action="Contact" class="hover:text-brand-400 transition-colors">Contact Us</a></li>
                        <li><a asp-controller="Home" asp-action="Faq" class="hover:text-brand-400 transition-colors">FAQs</a></li>
                        <li><a asp-controller="Home" asp-action="Returns" class="hover:text-brand-400 transition-colors">Returns Policy</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-stone-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-stone-600">
                <p>&copy; @DateTime.Now.Year ShoeShop. All rights reserved.</p>
                <p>Built with ASP.NET Core &amp; Tailwind CSS</p>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Mobile menu toggle
        document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
            document.getElementById('mobileMenu')?.classList.toggle('hidden');
        });

        // Auto-dismiss alerts after 5 s
        document.querySelectorAll('[role="alert"]').forEach(el => {
            setTimeout(() => el.remove(), 5000);
        });
    </script>
</body>
</html>
